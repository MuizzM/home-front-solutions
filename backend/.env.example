# Copy to `.env` and fill in the values. Never commit `.env`.
#
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-string

# Session lifetimes
JWT_DEFAULT_MINUTES=240
JWT_REMEMBER_DAYS=30

# CORS — comma-separated origins that can call this API with credentials.
# Include your production frontend + any staging URL + localhost for dev.
ALLOWED_ORIGINS=http://localhost:5173,https://www.homefrontsolutionsllc.com,https://homefrontsolutionsllc.com

# Cookie hardening — turn these on in production (HTTPS only).
# For local dev, leave COOKIE_SECURE=false and COOKIE_SAMESITE=lax.
# For cross-site prod deploys (frontend + api on different domains) use samesite=none + secure=true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
