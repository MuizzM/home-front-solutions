{
  "name": "home-front-solutions-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server --emptyOutDir false && node scripts/prerender.mjs",
    "preview": "vite preview",
    "cf:deploy": "npx wrangler pages deploy dist --project-name home-front-solutions-site",
    "seo:index-jobs": "node scripts/google-indexing-api.mjs updated",
    "seo:index-status": "node scripts/google-indexing-api.mjs status"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "google-auth-library": "^9.15.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
